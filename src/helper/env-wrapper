#!/usr/bin/env bash

source "$SNAP/helper/functions"

require_root

plugs_connected || exit 1


HOST=$(snapctl get server.host); export HOST
PORT=$(snapctl get server.port); export PORT

SERVER_SSL=$(snapctl get server.ssl); export SERVER_SSL
export HTTPS="${SERVER_SSL}"

FORCE_DISABLE_SSL=$(snapctl get server.force-disable-ssl); export FORCE_DISABLE_SSL

if [ "${FORCE_DISABLE_SSL}" != true ]; then
    unset FORCE_DISABLE_SSL
fi

USE_SECURE_COOKIE=$(snapctl get session.cookie-secure); export USE_SECURE_COOKIE

if [ "${HTTPS}" != true ] || [ "${FORCE_DISABLE_SSL}" == true ]; then
    unset HTTPS
    unset SERVER_SSL
    unset USE_SECURE_COOKIE
elif [ "${USE_SECURE_COOKIE}" != true ]; then
    unset USE_SECURE_COOKIE
fi

SESSION_SECRET=$(snapctl get session.secret); export SESSION_SECRET

MQTT_NAME=$(snapctl get mqtt.name); export MQTT_NAME

if [ -z "${MQTT_NAME}" ]; then
    unset MQTT_NAME
fi

if [ -n "$(snapctl get timezone)" ]; then
    TZ=$(snapctl get timezone); export TZ
fi

export ZWAVEJS_LOGS_DIR="${STORE_DIR}/logs/zwavejs"
BACKUPS_DIR="$(backup_dir)"; export BACKUPS_DIR

# When chained ahead of `npm`, run it from the app's module dir so its subcommands
# resolve; otherwise exec the target as-is. Explicit if/then avoids the `A && B || C`
# pitfall where a failed `cd` would silently fall through to an un-chdir'd exec.
if [ "$(basename "${1}")" = "npm" ]; then
    cd "${SNAP}/lib/node_modules/zwave-js-ui" || exit 1
fi
exec "${@}"
