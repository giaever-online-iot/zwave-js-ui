#!/usr/bin/env bash
# help — uniform overview: status, settings, commands. Replaces env-wrapper --help.
: "${SNAP:?SNAP must be set}"
source "$SNAP/helper/functions"
source "$SNAP/helper/ui"
source "$SNAP/helper/catalog"

snap_version() { yq eval '.version' "$SNAP/meta/snap.yaml"; }

service_state() {              # "enabled active", "disabled inactive", or "unknown"
    local line
    line="$(snapctl services "$SNAP_NAME.$SNAP_NAME" 2>/dev/null | awk 'NR==2 { print $2 " " $3 }')"
    echo "${line:-unknown}"
}

settings_rows() {              # catalog + live values -> TSV: key, value, default, description
    local key def desc cur
    while IFS=$'\t' read -r key _ def desc; do
        cur="$(snapctl get "$key" 2>/dev/null)"
        [ "$key" = "session.secret" ] && [ -n "$cur" ] && cur="(hidden)"
        printf '%s\t%s\t%s\t%s\n' "$key" "${cur:-(unset)}" "$def" "$desc"
    done < <(settings_catalog)
}

commands_rows() {
    printf '%s\n' \
        "$SNAP_NAME.enable	daemonize the service (autostart)" \
        "$SNAP_NAME.disable	stop + de-daemonize the service" \
        "$SNAP_NAME.restart	restart the service" \
        "$SNAP_NAME.exec	run the app in the foreground (debug boot issues)" \
        "$SNAP_NAME.logs [zui|zwjs]	follow live logs (merged by default)" \
        "$SNAP_NAME.backup …	ship backups off-box; see $SNAP_NAME.backup --help" \
        "$SNAP_NAME.help	this overview"
}

table_width() {                # stdin: TSV rows -> estimated bordered-table width
                               # sum(per-column max widths) + 3 padding/border per column + 1
    awk -F'\t' '
        { for (i=1;i<=NF;i++) if (length($i)>w[i]) w[i]=length($i); if (NF>nc) nc=NF }
        END { s=0; for (i=1;i<=nc;i++) s+=w[i]; print s + 3*nc + 1 }'
}

settings_stack() {             # stdin: TSV key,value,default,description -> stacked, width-aware.
                               # Default sits inline after the value, but drops to its own indented
                               # line when "key = value [default: …]" would overflow the terminal
                               # (e.g. a 40-char GPG fingerprint value). Description always indented.
    local key val def desc line cols; cols="$(ui_cols)"
    while IFS=$'\t' read -r key val def desc; do
        line="  $key = $val   [default: $def]"
        if [ "${#line}" -le "$cols" ]; then
            printf '%s\n' "$line"
        else
            printf '  %s = %s\n' "$key" "$val"
            printf '      [default: %s]\n' "$def"
        fi
        printf '      %s\n\n' "$desc"
    done
}

commands_stack() {             # stdin: TSV command,description -> command over indented description
    local cmd desc
    while IFS=$'\t' read -r cmd desc; do
        printf '  %s\n      %s\n' "$cmd" "$desc"
    done
}

# Width-aware: keep the gum table while it fits the terminal; otherwise stack so a
# narrow terminal never hard-wraps the columns into mush. Plain/syslog contexts are
# left untouched (aligned table, zero ANSI) — stacking only helps a styled TTY.
settings_render() {            # stdin: settings TSV
    local rows; rows="$(cat)"
    if [ "$(ui_ctx)" = styled ] && [ "$(printf '%s\n' "$rows" | table_width)" -gt "$(ui_cols)" ]; then
        printf '%s\n' "$rows" | settings_stack
    else
        printf '%s\n' "$rows" | ui_table "setting" "value" "default" "description"
    fi
}

commands_render() {            # stdin: commands TSV
    local rows; rows="$(cat)"
    if [ "$(ui_ctx)" = styled ] && [ "$(printf '%s\n' "$rows" | table_width)" -gt "$(ui_cols)" ]; then
        printf '%s\n' "$rows" | commands_stack
    else
        printf '%s\n' "$rows" | ui_table "command" "description"
    fi
}

main() {
    plugs_connected || ui_warn "Required interfaces are not connected — see the connect instructions above."
    ui_header "$SNAP_NAME" "$(snap_version) · $(service_state)"
    echo
    ui_print "The daemon is DISABLED by default after install. Enable it with:"
    ui_print "  sudo $SNAP_NAME.enable"
    echo
    settings_rows | settings_render
    echo
    ui_print "Set options with:  sudo snap set $SNAP_NAME <key>=<value>"
    ui_print "Other settings live in the web UI after start."
    echo
    commands_rows | commands_render
    echo
    ui_print "serial-port plug (needs snapd's experimental hotplug):"
    ui_print "  sudo snap set system experimental.hotplug=true && sudo systemctl restart snapd"
    ui_print "  sudo snap interface serial-port            # list available slots"
    ui_print "  sudo snap connect $SNAP_NAME:serial-port <slot name>"
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
